{
  "name": "next-ship",
  "version": "5.3.2",
  "bin": {
    "next-ship": "dist/index.js"
  },
  "files": [
    "dist/index.js"
  ],
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "check": "npx ultracite@latest check",
    "dead-code": "pnpm --filter @repo/testing build && knip --no-exit-code",
    "duplicate-code": "jscpd --min-lines 20 --min-tokens 80 --threshold 100 --reporters console --ignore \"**/node_modules/**,**/.next/**,**/coverage/**,**/dist/**,**/__tests__/**\" \"apps\" \"packages\"",
    "fix": "npx ultracite@latest fix",
    "format": "biome format --write .",
    "lint": "biome lint --write .",
    "biome:check": "biome check --write .",
    "biome:ci": "biome ci .",
    "test": "pnpm --filter @repo/testing build && turbo test",
    "analyze": "turbo analyze",
    "translate": "turbo translate",
    "boundaries": "turbo boundaries",
    "bump-deps": "npx npm-check-updates --deep -u -x recharts && pnpm install",
    "bump-ui": "npx shadcn@latest add --all --overwrite -c packages/design-system",
    "migrate": "cd packages/database && npx prisma format && npx prisma generate && npx prisma db push",
    "clean": "git clean -xdf node_modules",
    "check:flags": "bash scripts/check-feature-flags.sh",
    "check:versions": "bash scripts/check-version-drift.sh",
    "system-checks": "pnpm check:flags && pnpm check:versions && pnpm dead-code",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "playwright:install": "playwright install chromium",
    "test:flaky": "bash scripts/flaky-tests.sh check",
    "test:quarantined": "bash scripts/flaky-tests.sh list",
    "quarantine:add": "bash scripts/flaky-tests.sh quarantine",
    "quarantine:remove": "bash scripts/flaky-tests.sh unquarantine",
    "analyze:bundle": "cd apps/web && ANALYZE=true pnpm build",
    "tech-debt:scan": "bash scripts/tech-debt-scan.sh",
    "check:n-plus-one": "bash scripts/check-n-plus-one.sh",
    "boundaries": "turbo boundaries"
  },
  "devDependencies": {
    "@auto-it/first-time-contributor": "^11.3.6",
    "@biomejs/biome": "2.3.8",
    "@playwright/test": "^1.59.1",
    "@repo/typescript-config": "workspace:*",
    "@turbo/gen": "^2.6.3",
    "@types/node": "^24.10.1",
    "husky": "^9.1.7",
    "jscpd": "^4.0.5",
    "knip": "^5.64.1",
    "lint-staged": "^15.5.0",
    "tsup": "^8.5.1",
    "turbo": "^2.6.3",
    "typescript": "^5.9.3",
    "ultracite": "6.3.9",
    "vitest": "^4.0.15"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,md,mdx}": [
      "biome format --write --no-errors-on-unmatched"
    ],
    "*.{js,jsx,ts,tsx}": [
      "biome lint --write --no-errors-on-unmatched"
    ]
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "pnpm@10.24.0",
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "commander": "^14.0.2"
  },
  "pnpm": {
    "overrides": {
      "parse5": "^7.2.1",
      "next": "16.2.1"
    }
  },
  "type": "module"
}
