#!/bin/sh
# Pre-commit hook for next-ship
# 1. Lint staged files with Biome
# 2. Check for large files

echo "🔍 Running pre-commit checks..."

# Run lint-staged for Biome linting/formatting
npx lint-staged

# Check for large files (>1MB)
echo "📦 Checking for large files..."
LARGE_FILES=$(git diff --cached --name-only --diff-filter=ACM | xargs -I {} sh -c 'if [ -f "{}" ] && [ $(stat -f%z "{}" 2>/dev/null || stat -c%s "{}" 2>/dev/null) -gt 1048576 ]; then echo "{}"; fi' 2>/dev/null)

if [ -n "$LARGE_FILES" ]; then
    echo "❌ Error: Large files detected (>1MB):"
    echo "$LARGE_FILES"
    echo ""
    echo "Consider using Git LFS for large files:"
    echo "  git lfs track '*.extension'"
    exit 1
fi

echo "✅ Pre-commit checks passed!"
